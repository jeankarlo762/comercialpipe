{
  "name": "CRM NX",
  "version": "0.1.0",
  "private": true,
  "description": "CRM NX — CRM Comercial B2B com IA e n8n",
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "npm run db:generate --workspace=@CRM NX/api",
    "db:migrate": "npm run db:migrate --workspace=@CRM NX/api",
    "db:push": "npm run db:push --workspace=@CRM NX/api"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
